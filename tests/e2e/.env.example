# UI base URL is configured in playwright.config.ts via E2E_BASE_URL
E2E_BASE_URL=http://127.0.0.1:4200

# Path to Playwright storageState JSON for an authenticated admin session
JOBFLOW_UI_STORAGE_STATE_PATH=./tests/e2e/.auth/admin-storage-state.json

# API auth for end-to-end seeded business flow setup
JOBFLOW_API_BASE_URL=https://localhost:5099
JOBFLOW_API_BEARER_TOKEN=
JOBFLOW_ORGANIZATION_ID=
